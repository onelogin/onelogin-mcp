{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.onelogin/onelogin-mcp",
  "description": "MCP server for OneLogin API - manage users, apps, roles, and authentication",
  "repository": {
    "url": "https://github.com/onelogin/onelogin-mcp",
    "source": "github"
  },
  "version": "1.0.0",
  "packages": [
    {
      "registryType": "npm",
      "identifier": "@onelogin/onelogin-mcp",
      "version": "1.0.0",
      "runtimeHint": "npx",
      "transport": {
        "type": "stdio"
      },
      "environmentVariables": [
        {
          "name": "ONELOGIN_URL",
          "description": "Your OneLogin instance URL (e.g. https://mycompany.onelogin.com)",
          "isRequired": true,
          "isSecret": false
        },
        {
          "name": "ONELOGIN_CLIENT_ID",
          "description": "OneLogin OAuth2 API client ID",
          "isRequired": true,
          "isSecret": true
        },
        {
          "name": "ONELOGIN_CLIENT_SECRET",
          "description": "OneLogin OAuth2 API client secret",
          "isRequired": true,
          "isSecret": true
        }
      ]
    }
  ]
}
